{
  "family": "evaluacion2-pagos",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "256",
  "memory": "512",
  "executionRoleArn": "arn:aws:iam::926337675913:role/ecsTaskExecutionRole",
  "containerDefinitions": [
    {
      "name": "pagos",
      "image": "926337675913.dkr.ecr.us-east-1.amazonaws.com/pagos-repo:latest",
      "essential": true,
      "portMappings": [
        {
          "containerPort": 8002,
          "hostPort": 8002,
          "protocol": "tcp"
        }
      ],
      "environment": [
        {
          "name": "DATABASE_URL",
          "value": "postgresql://postgres:postgres@my-rds-db.endpoint:5432/ecommerce"
        },
        {
          "name": "MP_ACCESS_TOKEN",
          "value": "APP_USR-4795680976904507-050513-d428dd1b2f4fd762db76d5b2e9a55735-3379497295"
        }
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/evaluacion2-pagos",
          "awslogs-region": "us-east-1",
          "awslogs-stream-prefix": "ecs"
        }
      }
    }
  ]
}
