{
  "family": "evaluacion2-auditoria",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "256",
  "memory": "512",
  "executionRoleArn": "arn:aws:iam::926337675913:role/ecsTaskExecutionRole",
  "containerDefinitions": [
    {
      "name": "auditoria",
      "image": "926337675913.dkr.ecr.us-east-1.amazonaws.com/auditoria-repo:latest",
      "essential": true,
      "portMappings": [
        {
          "containerPort": 8004,
          "hostPort": 8004,
          "protocol": "tcp"
        }
      ],
      "environment": [
        {
          "name": "DATABASE_URL",
          "value": "postgresql://postgres:Ecommerce1234!@ecommerce-db-evaluacion.cqj4ase2sivc.us-east-1.rds.amazonaws.com:5432/postgres"
        }
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/evaluacion2-auditoria",
          "awslogs-region": "us-east-1",
          "awslogs-stream-prefix": "ecs"
        }
      }
    }
  ]
}
